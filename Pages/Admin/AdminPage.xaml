<Page x:Class="УП._01._01.Khachatryan.Pages.Admin.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:УП._01._01.Khachatryan.Pages.Admin"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Админ панель">

    <Grid Background="#db7093" >

        <TabControl Margin="20" Background="#db7093" Foreground="Black" BorderBrush="#fff000">


            <TabItem Header="Жалобы" >

                <Grid Margin="15">

                    <DataGrid x:Name="ComplaintsDG" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="1" BorderBrush="#fff000" HeadersVisibility="Column" VerticalGridLinesBrush="#fff000" HorizontalGridLinesBrush="Transparent" RowBackground="#db7093" Background="#db7093">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ID" Binding="{Binding ComplaintID}" Width="60" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTextColumn Header="Пользователь" Binding="{Binding User.DisplayName}" Width="250" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="*" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTextColumn Header="Книга" Binding="{Binding Book.Title}" Width="250" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt}" Width="200" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTemplateColumn Header="Действия" Width="220">

                                <DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <StackPanel Orientation="Horizontal">

                                            <Button Content="Отклонить" FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" Background="Transparent" BorderThickness="2" BorderBrush="#fff000" Margin="5" Padding="5" Click="RejectComplaintBtn_Click" Tag="{Binding}"/>

                                            <Button Content="Принять" FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" Background="#fff000" BorderThickness="0" Margin="5" Padding="5" Click="AcceptComplaintBtn_Click" Tag="{Binding}"/>


                                        </StackPanel>

                                    </DataTemplate>

                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>
            </TabItem>
            

            <TabItem Header="Разморозка">

                <Grid Margin="15">

                    <DataGrid x:Name="UnfreezeDG" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="1" BorderBrush="#fff000" HeadersVisibility="Column" VerticalGridLinesBrush="#fff000" HorizontalGridLinesBrush="Transparent" RowBackground="#db7093" Background="#db7093">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ID" Binding="{Binding UserID}" Width="60" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTextColumn Header="Пользователь" Binding="{Binding User1.DisplayName}" Width="*" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="*" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="200" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTemplateColumn Header="Действия" Width="220">

                                <DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <StackPanel Orientation="Horizontal">

                                            <Button Content="Отклонить" FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" Background="Transparent" BorderThickness="2" BorderBrush="#fff000" Margin="5" Padding="5" Click="RejectUnfreezeBtn_Click" Tag="{Binding}"/>
                                            <Button Content="Одобрить" FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" Background="#fff000" BorderThickness="0" Margin="5" Padding="5" Click="AcceptUnfreezeBtn_Click" Tag="{Binding}"/>


                                        </StackPanel>

                                    </DataTemplate>

                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </TabItem>

            <TabItem Header="Роль автора" >

                <Grid Margin="15">

                    <DataGrid x:Name="RoleRequestsDG" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="1" BorderBrush="#fff000" HeadersVisibility="Column" VerticalGridLinesBrush="#fff000" HorizontalGridLinesBrush="Transparent" RowBackground="#db7093" Background="#db7093">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ID" Binding="{Binding UserID}" Width="60" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTextColumn Header="Пользователь" Binding="{Binding User1.DisplayName}" Width="*" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTextColumn Header="Роль" Binding="{Binding RequestedRole}" Width="180" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="200" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTemplateColumn Header="Действия" Width="220">

                                <DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <StackPanel Orientation="Horizontal">

                                            <Button Content="Отклонить" FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" Background="Transparent" BorderThickness="2" BorderBrush="#fff000" Margin="5" Padding="5" Click="RejectRoleBtn_Click" Tag="{Binding}"/>
                                            <Button Content="Одобрить" FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" Background="#fff000" BorderThickness="0" Margin="5" Padding="5" Click="AcceptRoleBtn_Click" Tag="{Binding}"/>

                                        </StackPanel>

                                    </DataTemplate>

                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </TabItem>



            <TabItem Header="Замороженные">

                <Grid Margin="15">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <GroupBox Header="Замороженные книги" Grid.Row="0">

                        <DataGrid x:Name="FrozenBooksDG" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="1" BorderBrush="#fff000" HeadersVisibility="Column" VerticalGridLinesBrush="#fff000" HorizontalGridLinesBrush="Transparent" RowBackground="#db7093" Background="#db7093">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="ID" Binding="{Binding BookID}" Width="60" ElementStyle="{StaticResource CenterText}"/>

                                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>

                                <DataGridTextColumn Header="Автор" Binding="{Binding User.DisplayName}" Width="200" ElementStyle="{StaticResource CenterText}"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </GroupBox>


                    <GroupBox Header="Замороженные пользователи" Grid.Row="1">

                        <DataGrid x:Name="FrozenUsersDG" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="1" BorderBrush="#fff000" HeadersVisibility="Column" VerticalGridLinesBrush="#fff000" HorizontalGridLinesBrush="Transparent" RowBackground="#db7093" Background="#db7093">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding UserID}" Width="60" ElementStyle="{StaticResource CenterText}"/>

                                <DataGridTextColumn Header="Имя" Binding="{Binding DisplayName}"  Width="*" />

                                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="200" ElementStyle="{StaticResource CenterText}"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </GroupBox>

                </Grid>

            </TabItem>

            
            <TabItem Header="Пользователи" FontSize="18" FontFamily="{StaticResource MS}" Foreground="Black" Margin="1">

                <Grid Margin="15">

                    <DataGrid x:Name="UsersDG" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="1" BorderBrush="#fff000" HeadersVisibility="Column" VerticalGridLinesBrush="#fff000" HorizontalGridLinesBrush="Transparent" RowBackground="#db7093" Background="#db7093">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ID" Binding="{Binding UserID}" Width="60" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTextColumn Header="Имя" Binding="{Binding DisplayName}" Width="*" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="120" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTextColumn Header="Роль" Binding="{Binding Role.RoleName}" Width="160" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTemplateColumn Header="Действия" Width="*">

                                <DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <UniformGrid Columns="2">

                                            <Button Content="Сменить пароль" FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" Background="#fff000" BorderThickness="0" Margin="5" Padding="5" Click="ChangePasswordBtn_Click" Tag="{Binding}"/>
                                            <Button Content="Сделать автором" FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" Background="#fff000" BorderThickness="0" Margin="5" Padding="5" Click="SetAuthorBtn_Click" Tag="{Binding}"/>
                                            <Button Content="Заморозить" FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" BorderBrush="#fff000" BorderThickness="2" Background="Transparent" Margin="5" Padding="5" Click="FreezeUserBtn_Click" Tag="{Binding}"/>
                                            <Button Content="Удалить" FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" BorderBrush="#fff000" BorderThickness="2" Background="Transparent" Margin="5" Padding="5" Click="DeleteUserBtn_Click" Tag="{Binding}"/>

                                        </UniformGrid>

                                    </DataTemplate>

                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </TabItem>
            <TabControl.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#fff000"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="Padding" Value="10"/>
                    <Setter Property="FontSize" Value="18"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                </Style>

                <Style TargetType="DataGridCell">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="18"/>
                    <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Style.Triggers>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#db7093"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#fff000"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#db7093"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="BorderBrush" Value="#fff000"/>
                    <Setter Property="FontSize" Value="18"/>
                    <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" Background="{TemplateBinding Background}" BorderBrush="#fff000" BorderThickness="1" Padding="5">
                                    <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#fff000"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#fff000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style TargetType="GroupBox">
                    <Setter Property="Foreground" Value="#fff000"/>
                    <Setter Property="Margin" Value="10"/>
                    <Setter Property="BorderBrush" Value="#fff000"/>
                </Style>
                
            </TabControl.Resources>
            
        </TabControl>

    </Grid>
</Page>
