<Page x:Class="УП._01._01.Khachatryan.Pages.Admin.ChangePasswordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:УП._01._01.Khachatryan.Pages.Admin"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ChangePasswordPage">

    <Grid Background="#db7093">

        <Border BorderBrush="#fff000"
                BorderThickness="2"
                Width="400"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Смена пароля" FontSize="32" HorizontalAlignment="Center"/>

                <Separator Background="#fff000"/>

                <TextBlock Text="Пользователь"/>

                <TextBox x:Name="UserTB" IsReadOnly="True"/>

                <TextBlock Text="Новый пароль"/>

                <PasswordBox x:Name="PasswordPB"/>

                <TextBlock Text="Повторите пароль"/>

                <PasswordBox x:Name="RepeatPasswordPB"/>
                <UniformGrid Columns="2" Margin="5,15">
                    <Button Content="Отмена" Background="Transparent" BorderBrush="#fff000" BorderThickness="2" Click="BackBtn_Click"/>
                    <Button Content="Сохранить" Click="SaveBtn_Click"/>
                </UniformGrid>


            </StackPanel>

        </Border>

        <Grid.Resources>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                <Setter Property="FontSize" Value="26"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Margin" Value="5"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="Background" Value="#fff000"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="5"/>
                <Setter Property="Margin" Value="5"/>
            </Style>

            <Style TargetType="PasswordBox">
                <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="Background" Value="#fff000"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="5"/>
                <Setter Property="Margin" Value="5"/>
            </Style>

            <Style TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Background" Value="#fff000"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="5"/>
                <Setter Property="Margin" Value="5"/>
            </Style>

        </Grid.Resources>

    </Grid>
</Page>
