<Page x:Class="УП._01._01.Khachatryan.Pages.Author.AuthorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:УП._01._01.Khachatryan.Pages.Author"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница автора">

    <Grid Background="#db7093" Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="Transparent" Padding="20" Margin="15" BorderBrush="#fff000" BorderThickness="2">
            <DockPanel >
                <TextBlock Text="Мои книги" Margin="5" HorizontalAlignment="Center" FontFamily="{StaticResource MS}" FontWeight="Bold" FontSize="28" TextAlignment="Center" VerticalAlignment="Center"/>
                <Button Background="#fff000" BorderThickness="0" Content="+ Добавить книгу"  FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"  DockPanel.Dock="Right" Padding="5" Margin="5" Click="AddBookBtn_Click"/>
            </DockPanel>
        </Border>

        <DataGrid x:Name="BooksGrid" Grid.Row="1"  Margin ="15" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="1" BorderBrush="#fff000" HeadersVisibility="Column" VerticalGridLinesBrush="#fff000" HorizontalGridLinesBrush="Transparent" RowBackground="#db7093" Background="#db7093" MouseDoubleClick="BooksGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding BookID}" Width="50" ElementStyle="{StaticResource CenterText}"/>
                    <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*" />
                    <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt}" Width="*" />
                    <DataGridCheckBoxColumn Header="Заморожена" Binding="{Binding IsFrozen}" Width="130" />
                    <DataGridTemplateColumn Header="Действия" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Удалить" Background="Transparent" Foreground="Black" BorderThickness="1" BorderBrush="#fff000" Padding="5" Margin="5" Click="DeleteBtn_Click" Tag="{Binding}"/>
                                    <Button Content="Редактировать" Background="#fff000" BorderThickness="0" Foreground="Black" FontSize="16" FontFamily="{StaticResource MS}" FontWeight="Bold" HorizontalAlignment="Right" Padding="5" Margin="5" Click="EditBtn_Click" Tag="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>

            </DataGrid>
        <Grid.Resources>
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#fff000"/>
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="Padding" Value="10"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontFamily" Value="{StaticResource MS}"/>
            </Style>

            <Style TargetType="DataGridCell">
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Padding" Value="23"/>
                <Setter Property="FontSize" Value="18"/>
                <Style.Triggers>

                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#db7093"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="#fff000"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>
    </Grid>
</Page>
