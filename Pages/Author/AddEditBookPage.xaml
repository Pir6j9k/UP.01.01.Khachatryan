<Page x:Class="УП._01._01.Khachatryan.Pages.Author.AddEditBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:УП._01._01.Khachatryan.Pages.Author"
      mc:Ignorable="d" 
      d:DesignHeight="1000" d:DesignWidth="800"
      Title="AddEditBookPage">

    <Grid Background="#db7093" Margin="15">
        <ScrollViewer  VerticalScrollBarVisibility="Hidden">
            <Border Padding="30" BorderBrush="#fff000" BorderThickness="2" Margin="30">


                <StackPanel>

                    <TextBlock x:Name="TitleTB" Text="Добавление книги" FontSize="32" HorizontalAlignment="Center"/>

                    <Separator Background="#fff000"/>

                    <TextBlock Text="Название" />

                    <TextBox x:Name="BookNameTB" />

                    <TextBlock Text="Жанры"/>
                    <ListBox x:Name="GenresLB"
                             SelectionMode="Multiple"
                             Height="160"
                             Margin="10"
                             Background="#fff000"
                             BorderThickness="0"
                             DisplayMemberPath="GenreName" d:ItemsSource="{d:SampleData ItemCount=5}"/>

                    <TextBlock Text="Описание" />

                    <TextBox x:Name="DescriptionTB" Height="69" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Путь к обложке"/>
                    <TextBox x:Name="CoverTB"/>


                    <TextBlock Text="Текст книги"/>

                    <TextBox x:Name="ContentTB" Height="150" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                    <UniformGrid Columns="2" HorizontalAlignment="Center" Margin="5,15">
                        <Button Content="Назад" FontFamily="{StaticResource MS}" FontSize="28" FontWeight="Bold" Background="#fff000" BorderThickness="0" Margin="5" Padding="5" Click="BackBtn_Click"/>
                        <Button Content="Сохранить" FontFamily="{StaticResource MS}" FontSize="28" FontWeight="Bold" Background="#fff000" BorderThickness="0" Margin="5" Padding="5" Click="SaveBtn_Click"/>
                    </UniformGrid>
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontSize" Value="28"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Margin" Value="10"/>
                        </Style>

                        <Style TargetType="TextBox">
                            <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontSize" Value="26"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="#fff000"/>
                            <Setter Property="Margin" Value="10"/>
                            <Setter Property="Padding"  Value="10"/>

                        </Style>
                    </StackPanel.Resources>
                </StackPanel>

            </Border>
        </ScrollViewer>
    </Grid>
</Page>
