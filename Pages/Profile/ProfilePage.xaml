<Page x:Class="УП._01._01.Khachatryan.Pages.Profile.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:УП._01._01.Khachatryan.Pages.Profile"
      mc:Ignorable="d" 
      d:DesignHeight="1000" d:DesignWidth="800"
      Title="Профиль">

    <Grid Background="#db7093">
        <ScrollViewer VerticalScrollBarVisibility="Hidden">
            <StackPanel Margin="30">
                <Border Padding="30" BorderBrush="#fff000" BorderThickness="2"  Background="Transparent">
                    <StackPanel>

                        <TextBlock x:Name="NameTB" />

                        <TextBlock x:Name="LoginTB" />

                        <TextBlock x:Name="EmailTB" />

                        <TextBlock x:Name="RoleTB" />
                    </StackPanel>
                </Border>

                <Border x:Name="FrozenBorder" Padding="30" BorderBrush="#fff000" BorderThickness="2"  Background="Transparent" Visibility="Collapsed">
                    <StackPanel>

                        <TextBlock Text="Ваш аккаунт заморожен" FontSize="32"/>

                        <TextBlock x:Name="FreezeReasonTB"/>

                        <Button Content="Оспорить заморозку"  Click="AppealBtn_Click"/>

                    </StackPanel>
                </Border>

                <Border Padding="30" BorderBrush="#fff000" BorderThickness="2"  Background="Transparent">
                    <StackPanel>

                        <TextBlock Text="Стать автором" FontSize="32"/>

                        <TextBlock Text="Отправьте заявку на получение роли автора" FontSize="18"/>

                        <Button Content="Подать заявку" Click="RequestAuthorBtn_Click"/>

                    </StackPanel>
                </Border>

                <TextBlock Text="Мои отзывы" FontSize="32"/>

                <ItemsControl x:Name="ReviewsIC">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Padding="30" BorderBrush="#fff000" BorderThickness="2"  Background="Transparent">

                                <StackPanel>

                                    <TextBlock Text="{Binding Book.Title}" />

                                    <TextBlock Text="{Binding Rating, StringFormat=Оценка: {0}/10}" FontSize="18" />

                                    <TextBlock Text="{Binding ReviewText}" TextWrapping="Wrap"/>

                                    <TextBlock Text="{Binding CreatedAt}" FontSize="18"/>

                                    <StackPanel.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                            <Setter Property="FontSize" Value="26"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Margin" Value="5"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </StackPanel.Resources>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
        
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="FontSize" Value="26"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Margin" Value="5"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Background" Value="#fff000"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Margin" Value="5,0"/>
                <Setter Property="Padding" Value="5"/>
            </Style>

            <Style TargetType="Button">
                <Setter Property="Background" Value="#fff000"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                <Setter Property="Margin" Value="10"/>
                <Setter Property="Padding" Value="10"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
            </Style>
        </Grid.Resources>
    </Grid>
</Page>
