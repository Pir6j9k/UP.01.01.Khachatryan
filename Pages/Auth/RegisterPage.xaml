<Page x:Class="УП._01._01.Khachatryan.Pages.Auth.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:УП._01._01.Khachatryan.Pages.Auth"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegisterPage">

    <Grid Background="#db7093" HorizontalAlignment="Center" VerticalAlignment="Center">

        <Border BorderBrush="#fff000" BorderThickness="2" >

            <StackPanel Margin="20">

                <TextBlock Text="Регистрация" FontSize="32" HorizontalAlignment="Center"/>
                
                <Separator Background="#fff000"/>


                <TextBlock Text="Имя" />
                <TextBox x:Name="NameTB" />

                
                <TextBlock Text="Логин" />
                <TextBox x:Name="LoginTB" />


                <TextBlock Text="Почта"/>
                <TextBox x:Name="EmailTB"/>


                <TextBlock Text="Пароль"/>
                <PasswordBox x:Name="PasswordPB"/>

                <UniformGrid Columns="2" Margin="5,15">

                    <Button Content="Назад" FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" Background="Transparent" BorderThickness="2" BorderBrush="#fff000" Margin="5" Padding="5" Click="BackBtn_Click"/>

                    <Button Content="Регистрация" FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" Background="#fff000" BorderThickness="0" Margin="5" Padding="5" Click="RegisterBtn_Click"/>

                </UniformGrid>
                
                <StackPanel.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontSize" Value="26"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Margin" Value="5"/>
                    </Style>

                    <Style TargetType="TextBox">
                        <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontSize" Value="18"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="#fff000"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Margin" Value="5,0"/>
                        <Setter Property="Padding" Value="5"/>
                    </Style>

                    <Style TargetType="PasswordBox">
                        <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontSize" Value="18"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="#fff000"/>
                        <Setter Property="Margin" Value="5,0"/>
                        <Setter Property="Padding" Value="5"/>
                    </Style>
                    
                </StackPanel.Resources>
            </StackPanel>

        </Border>

    </Grid>
</Page>
