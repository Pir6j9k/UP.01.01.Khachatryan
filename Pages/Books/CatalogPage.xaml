<Page x:Class="УП._01._01.Khachatryan.Pages.Books.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:УП._01._01.Khachatryan.Pages.Books"
      mc:Ignorable="d" 
      d:DesignHeight="1000" d:DesignWidth="1000"
      Title="Каталог книг">

   
    <Grid Background="#DB7093" Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="Transparent" Padding="20" Margin="5" BorderBrush="#fff000" BorderThickness="2" >
            <WrapPanel>
                
                <TextBox x:Name="SearchTB" FontFamily="{StaticResource MS}" Background="#fff000" BorderThickness="0" Width="220" Foreground="Black" Height="35" Margin="5" FontSize="18" VerticalContentAlignment="Center" TextChanged="FiltersChanged"/>

                <UniformGrid Columns="2">

                    <ComboBox x:Name="SortCB"  SelectionChanged="FiltersChanged" VerticalAlignment="Center">

                        <ComboBoxItem Content="Без сортировки"/>
                        <ComboBoxItem Content="По названию"/>
                        <ComboBoxItem Content="По рейтингу"/>

                    </ComboBox>

                    <ComboBox x:Name="GenreCB" DisplayMemberPath="GenreName" SelectionChanged="FiltersChanged"/>
                </UniformGrid>
            </WrapPanel>

        </Border>

        <ListView x:Name="BooksLV" Grid.Row="1" Background="Transparent"  BorderThickness="0"  ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" d:ItemsSource="{d:SampleData ItemCount=5}">

            <ListView.ItemsPanel>

                <ItemsPanelTemplate>

                    <WrapPanel Orientation="Horizontal"/>

                </ItemsPanelTemplate>

            </ListView.ItemsPanel>

            <ListView.ItemTemplate>

                <DataTemplate>

                    <Border Margin="10" Padding="10" BorderBrush="#fff000" BorderThickness="2" Background="Transparent">

                        <StackPanel>
                            
                            <Border Width="250" Height="350" BorderThickness="0"  Background="Transparent" Margin="5" Padding="10">
                                <Image Source="{Binding CoverPath}" Stretch="Uniform"/>
                            </Border>
                            
                            <TextBlock Text="{Binding Title}" FontSize="28"/>

                            <TextBlock Text="{Binding User.DisplayName}" FontSize="18" TextAlignment="Center"/>

                            <TextBlock Text="{Binding Reviews.Count, StringFormat=Отзывы: {0}}" />

                            <StackPanel>
                                <Button Content="Открыть" Tag="{Binding}" Click="OpenBookBtn_Click" FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" Background="#fff000" BorderThickness="0" Margin="5" Padding="5"/>
                                <Button Content="В планах" Tag="{Binding}" Click="AddToPlanBtn_Click" FontFamily="{StaticResource MS}" FontSize="18" FontWeight="Bold" Background="#fff000" BorderThickness="0" Margin="5" Padding="5"/>
                            </StackPanel>

                            <StackPanel.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="18"/>
                                    <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </StackPanel.Resources>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        
        <Grid.Resources>
            <Style TargetType="ComboBox">
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="FontFamily" Value="{StaticResource MS}"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Padding" Value="5"/>
            </Style>
        </Grid.Resources>
    </Grid>
</Page>
